# Copy this file to `.env` and fill in your own keys. `.env` is gitignored.
# Never commit real API keys — load them from the environment instead.

# DeepSeek (the coordinator + subagent model provider). Referenced by
# harness.json as ${DEEPSEEK_API_KEY}; an exported DEEPSEEK_API_KEY also
# overrides any value in harness.json.
DEEPSEEK_API_KEY=

# Serper.dev key for the controlled web-search tool. Referenced by harness.json
# as ${SERPER_API_KEY}; an exported SERPER_API_KEY overrides the file value.
SERPER_API_KEY=

# Optional: only needed if you run the legacy frontend/app.py launcher.
SILICONFLOW_API_KEY=
